    {
      "parameters": {
        "select": "channel",
        "channelId": { "value": "={{ $json.slack_channel }}", "__rl": true, "mode": "name" },
        "blocksUi": "=[\n  {\n    \"type\": \"header\",\n    \"text\": { \"type\": \"plain_text\", \"text\": \"📊 Investor Update Sent — {{ $json.period }}\" }\n  },\n  {\n    \"type\": \"section\",\n    \"fields\": [\n      { \"type\": \"mrkdwn\", \"text\": \"*Company:*\\n{{ $json.company_name }}\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Period:*\\n{{ $json.period }}\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Health:*\\n{{ $json.health_score }}/10 — {{ $json.health_label }}\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*MRR Growth:*\\n{{ $json.mrr_growth_pct }}%\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Runway:*\\n{{ $json.runway_months }} months\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Next Raise:*\\n{{ $json.next_raise_signal }}\" }\n    ]\n  },\n  {\n    \"type\": \"section\",\n    \"text\": { \"type\": \"mrkdwn\", \"text\": \"*💡 Key Insight:*\\n{{ $json.key_insight }}\" }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": { \"type\": \"mrkdwn\", \"text\": \"*⚠️ Risk Flag:*\\n{{ $json.risk_flag }}\" }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": { \"type\": \"mrkdwn\", \"text\": \"*📝 Summary:*\\n{{ $json.executive_summary }}\" }\n  },\n  {\n    \"type\": \"context\",\n    \"elements\": [\n      { \"type\": \"mrkdwn\", \"text\": \"Sent to: {{ $json.investor_emails }} | Cost: ${{ $json.estimated_cost_usd }} | Tokens: {{ $json.tokens_used }}\" }\n    ]\n  }\n]",
        "otherOptions": {}
      },
      "id": "node-slack",
      "name": "Slack — Team Digest",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [1780, 500],
      "credentials": { "slackApi": { "id": "slack-credential-id", "name": "Slack OAuth2" } }
    },
    {
      "parameters": {
        "options": {}
      },

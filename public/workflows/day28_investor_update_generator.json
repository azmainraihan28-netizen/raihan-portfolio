        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"company\": \"{{ $json.company_name }}\",\n  \"period\": \"{{ $json.period }}\",\n  \"subject_line\": \"{{ $json.subject_line }}\",\n  \"health_score\": {{ $json.health_score }},\n  \"health_label\": \"{{ $json.health_label }}\",\n  \"mrr_growth_pct\": {{ $json.mrr_growth_pct }},\n  \"customer_growth_pct\": {{ $json.customer_growth_pct }},\n  \"key_insight\": \"{{ $json.key_insight }}\",\n  \"risk_flag\": \"{{ $json.risk_flag }}\",\n  \"next_raise_signal\": \"{{ $json.next_raise_signal }}\",\n  \"executive_summary\": \"{{ $json.executive_summary }}\",\n  \"investors_notified\": \"{{ $json.investor_emails }}\",\n  \"tokens_used\": {{ $json.tokens_used }},\n  \"estimated_cost_usd\": \"{{ $json.estimated_cost_usd }}\"\n}",
        "options": { "responseCode": 200 }

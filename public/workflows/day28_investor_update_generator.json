      "id": "node-if-email",
      "name": "Has Investor Emails?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "// Split comma-separated investor emails into individual items\nconst item = $input.first().json;\nconst emails = item.investor_emails\n  .split(',')\n  .map(e => e.trim())\n  .filter(e => e.includes('@'));\n\nreturn emails.map(email => ({\n  json: { ...item, send_to_email: email }\n}));\n"
      },
      "id": "node-split-emails",
      "name": "Split Investor Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 220]

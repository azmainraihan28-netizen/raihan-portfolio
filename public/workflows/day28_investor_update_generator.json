            { "id": "a21","name": "slack_channel",    "value": "={{ $json.body.slack_channel || '#investor-updates' }}", "type": "string" },
            { "id": "a22","name": "timestamp",        "value": "={{ new Date().toISOString() }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-set",
      "name": "Set Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json.company_name }}",
              "rightValue": "Your Company",
              "operator": { "type": "string", "operation": "notEquals" }
            },
            {
              "id": "cond2",
              "leftValue": "={{ $json.mrr }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }

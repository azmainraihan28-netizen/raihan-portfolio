        "options": {}
      },
      "id": "node-validate",
      "name": "Validate Inputs",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"Missing required fields: company_name and mrr must be provided\" }",
        "options": { "responseCode": 400 }
      },
      "id": "node-error-400",
      "name": "Return 400 Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 460]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.openai_key }}" },
            { "name": "Content-Type",  "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert startup CFO and investor relations writer. Generate professional, concise investor updates in plain English. Avoid jargon. Be transparent. Format: JSON only.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a complete investor update for {{ $json.company_name }} for {{ $json.period }}.\\n\\nMETRICS:\\n- MRR: ${{ $json.mrr }} (prev: ${{ $json.mrr_prev }})\\n- ARR: ${{ $json.arr }}\\n- Customers: {{ $json.customers }} (prev: {{ $json.customers_prev }})\\n- Churn Rate: {{ $json.churn_rate }}%\\n- Burn Rate: ${{ $json.burn_rate }}/mo\\n- Runway: {{ $json.runway_months }} months\\n- Cash on Hand: ${{ $json.cash_on_hand }}\\n\\nFOUNDER INPUT:\\n- Top Wins: {{ $json.top_wins }}\\n- Challenges: {{ $json.challenges }}\\n- Next Milestones: {{ $json.next_milestones }}\\n- Asks: {{ $json.asks }}\\n\\nReturn JSON with these fields:\\n1. subject_line: Professional email subject line (e.g. \\\"[Company] Investor Update — Q2 2025\\\")\\n2. email_body: Full HTML investor update email (750–1,000 words, structured with sections: Headline Number, Business Overview, Key Metrics Table, Wins, Challenges & How We're Addressing Them, Next 90 Days, Asks, Closing Note)\\n3. executive_summary: 3-sentence plain-text summary for Slack/quick read\\n4. health_score: Overall business health score 1–10 (10 = exceptional)\\n5. health_label: One of: Critical / Struggling / Stable / Growing / Thriving\\n6. mrr_growth_pct: MRR growth % vs prior period (number)\\n7. customer_growth_pct: Customer growth % vs prior period (number)\\n8. key_insight: One bold 1-sentence insight investors should focus on\\n9. risk_flag: Biggest risk visible in the data (1 sentence) or null if no obvious risk\\n10. next_raise_signal: One of: Not Now / 6 Months / 3 Months / Raising Now — based on runway and growth\"\n    }\n  ],\n  \"max_tokens\": 2000,\n  \"temperature\": 0.4\n}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-openai",
      "name": "OpenAI — Generate Investor Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst raw = item.choices?.[0]?.message?.content || '{}';\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  parsed = {\n    subject_line: `[${item.company_name}] Investor Update — ${item.period}`,\n    email_body: '<p>Investor update content could not be generated. Please retry.</p>',\n    executive_summary: 'Update generation failed. Please retry.',\n    health_score: 5,\n    health_label: 'Stable',\n    mrr_growth_pct: 0,\n    customer_growth_pct: 0,\n    key_insight: 'Unable to generate insight.',\n    risk_flag: null,\n    next_raise_signal: 'Not Now'\n  };\n}\n\n// Pull prev item data back\nconst prev = $('Set Fields').first().json;\n\nreturn [{\n  json: {\n    ...prev,\n    subject_line:         parsed.subject_line || '',\n    email_body:           parsed.email_body || '',\n    executive_summary:    parsed.executive_summary || '',\n    health_score:         parsed.health_score || 5,\n    health_label:         parsed.health_label || 'Stable',\n    mrr_growth_pct:       parsed.mrr_growth_pct || 0,\n    customer_growth_pct:  parsed.customer_growth_pct || 0,\n    key_insight:          parsed.key_insight || '',\n    risk_flag:            parsed.risk_flag || 'None identified',\n    next_raise_signal:    parsed.next_raise_signal || 'Not Now',\n    tokens_used:          item.usage?.total_tokens || 0,\n    estimated_cost_usd:   ((item.usage?.total_tokens || 0) * 0.00000015).toFixed(5)\n  }\n}];\n"
      },
      "id": "node-parse",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "value": "={{ $json.sheet_id }}", "__rl": true, "mode": "id" },
        "sheetName": { "value": "Investor Updates", "__rl": true, "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Timestamp":             "={{ $json.timestamp }}",
            "Company":               "={{ $json.company_name }}",
            "Founder":               "={{ $json.founder_name }}",
            "Period":                "={{ $json.period }}",
            "MRR ($)":               "={{ $json.mrr }}",
            "MRR Prev ($)":          "={{ $json.mrr_prev }}",
            "MRR Growth (%)":        "={{ $json.mrr_growth_pct }}",
            "ARR ($)":               "={{ $json.arr }}",
            "Customers":             "={{ $json.customers }}",
            "Customer Growth (%)":   "={{ $json.customer_growth_pct }}",
            "Churn Rate (%)":        "={{ $json.churn_rate }}",
            "Burn Rate ($)":         "={{ $json.burn_rate }}",
            "Runway (Mo)":           "={{ $json.runway_months }}",
            "Cash on Hand ($)":      "={{ $json.cash_on_hand }}",
            "Health Score":          "={{ $json.health_score }}",
            "Health Label":          "={{ $json.health_label }}",
            "Key Insight":           "={{ $json.key_insight }}",
            "Risk Flag":             "={{ $json.risk_flag }}",
            "Next Raise Signal":     "={{ $json.next_raise_signal }}",
            "Subject Line":          "={{ $json.subject_line }}",
            "Investor Emails":       "={{ $json.investor_emails }}",
            "Tokens Used":           "={{ $json.tokens_used }}",
            "Cost (USD)":            "={{ $json.estimated_cost_usd }}"
          }
        },
        "options": {}
      },
      "id": "node-sheets",
      "name": "Google Sheets — Log Update",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1340, 300]

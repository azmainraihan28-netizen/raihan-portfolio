    {
      "parameters": {
        "model": "gpt-4o-mini",
        "options": {
          "temperature": 0.3,
          "maxTokens": 600
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an AI standup analyzer. Given a team member's daily standup update, you will structure it cleanly and extract intelligence. Always respond with valid JSON only — no markdown, no extra text."
            },
            {
              "role": "user",
              "content": "Analyze this standup update and return a JSON object with these fields:\n- structured_yesterday: (string) Cleaned, bullet-pointed version of what they did yesterday\n- structured_today: (string) Cleaned, bullet-pointed plan for today\n- blockers_detected: (boolean) true if there are real blockers, false if none\n- blocker_summary: (string) Brief summary of blockers, or 'None' if no blockers\n- blocker_severity: (string) 'none' | 'low' | 'medium' | 'high'\n- risk_flag: (boolean) true if today's plan seems risky or unrealistic\n- productivity_estimate: (string) 'low' | 'medium' | 'high' — based on how clear and focused the plan is\n- sentiment: (string) 'positive' | 'neutral' | 'negative' — based on overall tone\n- slack_message: (string) A clean, well-formatted Slack message for this person's standup (use emoji, plain text, no markdown headers). Max 150 words.\n- manager_note: (string) A one-line private note to the manager about this team member's update today\n\nEmployee: {{ $json.employee_name }}\nTeam: {{ $json.team }}\nMood: {{ $json.mood }}\nYesterday: {{ $json.what_done_yesterday }}\nToday: {{ $json.what_doing_today }}\nBlockers: {{ $json.blockers }}"
            }
          ]
        }
      },
      "id": "a1b2c3d4-0004-4004-8004-000000000004",
      "name": "OpenAI — Analyze Standup",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.7,
      "position": [900, 220],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst rawContent = item.message?.content || item.choices?.[0]?.message?.content || '{}';\n\nlet ai = {};\ntry {\n  const cleaned = rawContent.replace(/```json|```/g, '').trim();\n  ai = JSON.parse(cleaned);\n} catch (e) {\n  ai = {\n    structured_yesterday: $('Set — Normalize Fields').first().json.what_done_yesterday,\n    structured_today: $('Set — Normalize Fields').first().json.what_doing_today,\n    blockers_detected: false,\n    blocker_summary: 'None',\n    blocker_severity: 'none',\n    risk_flag: false,\n    productivity_estimate: 'medium',\n    sentiment: 'neutral',\n    slack_message: `📋 *${$('Set — Normalize Fields').first().json.employee_name}* shared their standup.`,\n    manager_note: 'Could not parse standup details.'\n  };\n}\n\nconst base = $('Set — Normalize Fields').first().json;\n\nreturn [{\n  json: {\n    ...base,\n    structured_yesterday: ai.structured_yesterday || base.what_done_yesterday,\n    structured_today: ai.structured_today || base.what_doing_today,\n    blockers_detected: ai.blockers_detected || false,\n    blocker_summary: ai.blocker_summary || 'None',\n    blocker_severity: ai.blocker_severity || 'none',\n    risk_flag: ai.risk_flag || false,\n    productivity_estimate: ai.productivity_estimate || 'medium',\n    sentiment: ai.sentiment || 'neutral',\n    slack_message: ai.slack_message || `📋 Standup from ${base.employee_name}`,\n    manager_note: ai.manager_note || ''\n  }\n}];"
      },
      "id": "a1b2c3d4-0005-4005-8005-000000000005",
      "name": "Code — Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

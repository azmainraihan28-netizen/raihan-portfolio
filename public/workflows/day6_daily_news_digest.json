      "parameters": {
        "sendTo": "={{ $json.config.recipient_email }}",
        "subject": "={{ $json.digest.subject }}",
        "message": "={{ $json.htmlEmail }}",
        "options": {
          "isHtml": true,
          "replyTo": ""
        }
      },

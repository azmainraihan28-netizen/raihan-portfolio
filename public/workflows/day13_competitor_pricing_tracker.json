            "Monthly Price": "={{ $json.monthlyPrice }}",
            "Annual Price": "={{ $json.annualPrice }}",
            "Currency": "={{ $json.currency }}",
            "Pricing Model": "={{ $json.pricingModel }}",
            "Free Tier": "={{ $json.freeTierAvailable }}",
            "Trial Days": "={{ $json.trialDays }}",
            "Discount": "={{ $json.discountOffered }}",
            "Usage Limits": "={{ $json.usageLimits }}",
            "Key Features": "={{ $json.keyFeatures.join(', ') }}",

      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Split Out Competitors",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "options": {
          "timeout": 15000,
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "HTTP — Scrape Pricing Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extract readable text from scraped HTML\nconst html = $input.item.json.data || '';\nconst name = $input.item.json.name || 'Unknown';\nconst url = $input.item.json.url || '';\nconst plan = $input.item.json.plan || '';\n\n// Strip HTML tags and collapse whitespace\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\n// Limit to 3,000 chars for AI (pricing page content is usually near the top)\nconst snippet = text.slice(0, 3000);\n\nreturn [{\n  json: {\n    name,\n    url,\n    plan,\n    pageSnippet: snippet,\n    scrapedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Code — Clean HTML → Text Snippet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "create",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "You are a pricing intelligence analyst. Extract pricing data from the following competitor pricing page text.\n\nCompetitor: {{ $json.name }}\nPlan being tracked: {{ $json.plan }}\nPage URL: {{ $json.url }}\n\nPage content:\n{{ $json.pageSnippet }}\n\nExtract and return ONLY valid JSON (no markdown, no explanation) in this exact format:\n{\n  \"competitor\": \"string\",\n  \"plan\": \"string\",\n  \"monthlyPrice\": \"string (e.g. $49/mo or 'Not found')\",\n  \"annualPrice\": \"string (e.g. $39/mo billed annually or 'Not found')\",\n  \"currency\": \"string (USD/EUR/GBP etc)\",\n  \"keyFeatures\": [\"feature1\", \"feature2\", \"feature3\"],\n  \"usageLimits\": \"string (e.g. Up to 5 users, 100GB storage)\",\n  \"freeTierAvailable\": true/false,\n  \"trialDays\": number or 0,\n  \"pricingModel\": \"per_seat | flat_rate | usage_based | tiered | freemium\",\n  \"discountOffered\": \"string or 'None'\",\n  \"summary\": \"1-sentence insight about their positioning\",\n  \"confidence\": \"high | medium | low\"\n}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "OpenAI — Extract Pricing Data",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "jsCode": "// Safely parse OpenAI JSON response\nlet raw = '';\ntry {\n  raw = $input.item.json.message?.content || $input.item.json.choices?.[0]?.message?.content || '';\n} catch(e) {\n  raw = '';\n}\n\nlet parsed = {};\ntry {\n  // Remove markdown code fences if present\n  const cleaned = raw.replace(/```json/gi, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    competitor: $input.item.json.name || 'Unknown',\n    plan: $input.item.json.plan || 'Unknown',\n    monthlyPrice: 'Parse error',\n    annualPrice: 'Parse error',\n    currency: 'USD',\n    keyFeatures: [],\n    usageLimits: 'Unknown',\n    freeTierAvailable: false,\n    trialDays: 0,\n    pricingModel: 'unknown',\n    discountOffered: 'None',\n    summary: 'Could not parse pricing page',\n    confidence: 'low'\n  };\n}\n\nconst now = new Date();\nreturn [{\n  json: {\n    ...parsed,\n    url: $input.item.json.url || '',\n    scrapedAt: $input.item.json.scrapedAt || now.toISOString(),\n    date: now.toISOString().split('T')[0],\n    time: now.toTimeString().slice(0, 5),\n    weekday: now.toLocaleDateString('en-US', { weekday: 'long' })\n  }\n}];"
      },
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Code — Parse AI Pricing JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "={{ $('Config — Set Competitors List').item.json.sheetsId }}",

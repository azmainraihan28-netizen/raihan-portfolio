    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "options": {}
      },
      "id": "a1b2c3d4-0010-0010-0010-000000000010",
      "name": "Aggregate — All Competitors",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [2220, 200]
    },
    {
      "parameters": {
        "jsCode": "// Build a rich Slack daily digest message\nconst items = $input.all();\nconst data = items.map(i => i.json);\nconst date = data[0]?.date || new Date().toISOString().split('T')[0];\n\nlet rows = data.map(d => {\n  const priceInfo = d.monthlyPrice !== 'Not found' ? `*${d.monthlyPrice}* /mo` : '_Price not found_';\n  const annual = d.annualPrice !== 'Not found' ? ` (${d.annualPrice} annual)` : '';\n  const trial = d.trialDays > 0 ? ` | ${d.trialDays}-day trial` : '';\n  const free = d.freeTierAvailable ? ' | 🆓 Free tier' : '';\n  return `• *${d.competitor}* — ${d.plan} Plan\\n  ${priceInfo}${annual}${trial}${free}\\n  📌 ${d.summary}\\n  🔗 ${d.url}`;\n}).join('\\n\\n');\n\nconst message = `:bar_chart: *Competitor Pricing Digest — ${date}*\\n\\n${rows}\\n\\n_Tracked by your n8n Pricing Intelligence Workflow_`;\n\nreturn [{ json: { slackMessage: message } }];"
      },
      "id": "a1b2c3d4-0011-0011-0011-000000000011",
      "name": "Code — Build Slack Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 200]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "pricing-alerts",
          "mode": "name"
        },
        "text": "={{ $json.slackMessage }}",
        "otherOptions": {
          "mrkdwn": true
        }
      },
      "id": "a1b2c3d4-0012-0012-0012-000000000012",
      "name": "Slack — Send Pricing Digest",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [2660, 200]
    },

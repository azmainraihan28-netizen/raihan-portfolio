    {
      "parameters": {
        "sendTo": "={{ $json.employee_email }}",
        "subject": "⚠️ Expense {{ $json.expense_id }} — Pending Approval",
        "emailType": "html",
        "message": "<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#333'><div style='background:#fff3cd;border-left:4px solid #ffc107;padding:15px;border-radius:4px;margin-bottom:20px'><h2 style='margin:0;color:#856404'>⚠️ Expense Pending Review</h2></div><p>Hi <strong>{{ $json.employee_name }}</strong>,</p><p>Your expense submission has been received but requires <strong>{{ $json.policy_flag === 'OVER_LIMIT' ? 'manager approval (over budget limit)' : 'finance team review' }}</strong>.</p><table style='width:100%;border-collapse:collapse;margin:20px 0'><tr style='background:#f8f9fa'><td style='padding:10px;border:1px solid #dee2e6'><strong>Expense ID</strong></td><td style='padding:10px;border:1px solid #dee2e6'>{{ $json.expense_id }}</td></tr><tr><td style='padding:10px;border:1px solid #dee2e6'><strong>Vendor</strong></td><td style='padding:10px;border:1px solid #dee2e6'>{{ $json.vendor_name }}</td></tr><tr style='background:#f8f9fa'><td style='padding:10px;border:1px solid #dee2e6'><strong>Amount</strong></td><td style='padding:10px;border:1px solid #dee2e6'>{{ $json.total_amount }} {{ $json.currency }}</td></tr><tr><td style='padding:10px;border:1px solid #dee2e6'><strong>Category</strong></td><td style='padding:10px;border:1px solid #dee2e6'>{{ $json.category }} › {{ $json.subcategory }}</td></tr><tr style='background:#f8f9fa'><td style='padding:10px;border:1px solid #dee2e6'><strong>Status</strong></td><td style='padding:10px;border:1px solid #dee2e6'><span style='color:#856404;font-weight:bold'>{{ $json.policy_flag }}</span></td></tr><tr><td style='padding:10px;border:1px solid #dee2e6'><strong>Reason</strong></td><td style='padding:10px;border:1px solid #dee2e6'>{{ $json.policy_reason }}</td></tr></table><p>Your manager ({{ $json.manager_email || 'Finance Team' }}) has been notified and will review this shortly.</p><p style='font-size:12px;color:#6c757d;margin-top:30px'>This is an automated message from your expense management system.</p></body></html>",
        "options": {}

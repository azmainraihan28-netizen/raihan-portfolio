        },
        "messages": {
          "values": [
            {
              "content": "You are an expert finance AI that extracts and categorizes expense data from receipt text.\n\nAnalyze the following receipt/expense text and return ONLY a valid JSON object with no markdown, no explanation.\n\nReceipt text:\n{{ $json.receipt_text }}\n\nEmployee: {{ $json.employee_name }}\nDepartment: {{ $json.department }}\nCurrency: {{ $json.currency }}\nBudget Limit: {{ $json.budget_limit }} {{ $json.currency }}\n\nReturn this exact JSON structure:\n{\n  \"vendor_name\": \"string — name of vendor/merchant\",\n  \"transaction_date\": \"string — date of transaction (YYYY-MM-DD or as found)\",\n  \"total_amount\": \"number — total amount paid\",\n  \"tax_amount\": \"number — tax amount (0 if not found)\",\n  \"subtotal\": \"number — amount before tax\",\n  \"currency\": \"string — currency code\",\n  \"category\": \"string — one of: Meals & Entertainment, Travel & Transport, Accommodation, Software & Subscriptions, Office Supplies, Marketing & Advertising, Training & Education, Medical, Utilities, Other\",\n  \"subcategory\": \"string — more specific category (e.g., Business Lunch, Uber, Flight, Hotel, SaaS Tool)\",\n  \"payment_method\": \"string — Card/Cash/Online/Unknown\",\n  \"business_purpose\": \"string — inferred business purpose in one sentence\",\n  \"is_billable\": \"boolean — is this likely a client-billable expense?\",\n  \"policy_flag\": \"string — 'APPROVED', 'NEEDS_REVIEW', or 'OVER_LIMIT' — flag OVER_LIMIT if total_amount exceeds budget_limit\",\n  \"policy_reason\": \"string — brief reason for flag (empty string if APPROVED)\",\n  \"reimbursable\": \"boolean — is this likely reimbursable to the employee?\",\n  \"confidence_score\": \"number — 1-10, how confident you are in the extraction\",\n  \"notes\": \"string — any important notes or warnings about this receipt\"\n}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "OpenAI — Extract & Categorize Expense",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst aiRaw = input.message?.content || input.choices?.[0]?.message?.content || '';\n\n// Clean and parse AI JSON\nlet expense = {};\ntry {\n  const cleaned = aiRaw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  expense = JSON.parse(cleaned);\n} catch (e) {\n  // Fallback if AI response can't be parsed\n  expense = {\n    vendor_name: 'Unknown Vendor',\n    transaction_date: new Date().toISOString().split('T')[0],\n    total_amount: 0,\n    tax_amount: 0,\n    subtotal: 0,\n    currency: input.currency || 'USD',\n    category: 'Other',\n    subcategory: 'Unknown',\n    payment_method: 'Unknown',\n    business_purpose: 'Unable to extract — please review manually',\n    is_billable: false,\n    policy_flag: 'NEEDS_REVIEW',\n    policy_reason: 'AI extraction failed — manual review required',\n    reimbursable: true,\n    confidence_score: 1,\n    notes: 'Parse error: ' + e.message\n  };\n}\n\n// Apply budget limit check (override AI if needed)\nconst budgetLimit = parseFloat(input.budget_limit) || 500;\nif (parseFloat(expense.total_amount) > budgetLimit && expense.policy_flag !== 'OVER_LIMIT') {\n  expense.policy_flag = 'OVER_LIMIT';\n  expense.policy_reason = `Amount ${expense.total_amount} ${expense.currency} exceeds limit of ${budgetLimit} ${input.currency}`;\n}\n\n// Build the full expense record\nconst record = {\n  // Employee info\n  employee_name: input.employee_name,\n  employee_email: input.employee_email,\n  department: input.department,\n  manager_email: input.manager_email,\n  submission_date: input.submission_date,\n  // Extracted expense data\n  vendor_name: expense.vendor_name || 'Unknown',\n  transaction_date: expense.transaction_date || input.submission_date,\n  total_amount: expense.total_amount || 0,\n  subtotal: expense.subtotal || 0,\n  tax_amount: expense.tax_amount || 0,\n  currency: expense.currency || input.currency,\n  category: expense.category || 'Other',\n  subcategory: expense.subcategory || '',\n  payment_method: expense.payment_method || 'Unknown',\n  business_purpose: expense.business_purpose || '',\n  is_billable: expense.is_billable ? 'Yes' : 'No',\n  policy_flag: expense.policy_flag || 'APPROVED',\n  policy_reason: expense.policy_reason || '',\n  reimbursable: expense.reimbursable !== false ? 'Yes' : 'No',\n  confidence_score: expense.confidence_score || 5,\n  notes: expense.notes || '',\n  slack_channel: input.slack_channel,\n  sheets_id: input.sheets_id,\n  // Derived helpers\n  needs_approval: expense.policy_flag !== 'APPROVED',\n  expense_id: 'EXP-' + Date.now()\n};\n\nreturn [{ json: record }];\n"
      },

      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Has Leads?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "leads",
        "options": {}
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Split Leads",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [880, 200]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "=You are a world-class cold email copywriter who specializes in B2B outreach.\n\nWrite a highly personalized cold email for the following lead:\n\nLead Name: {{ $json.name }}\nLead Role: {{ $json.role }}\nLead Company: {{ $json.company }}\nLead Industry: {{ $json.industry || 'Not specified' }}\nLead LinkedIn Bio/About: {{ $json.bio || 'Not provided' }}\nLead Pain Point Context: {{ $json.pain_point || 'Operational efficiency and automation' }}\n\nSender: {{ $('Set Variables').item.json.sender_name }}, {{ $('Set Variables').item.json.sender_role }}\nOffer: {{ $('Set Variables').item.json.your_offer }}\n\nRules:\n1. Subject line must be under 9 words, personalized, curiosity-driven — NO generic phrases like 'Quick question' or 'Following up'\n2. Opening line must reference something SPECIFIC about their role or company — not a generic compliment\n3. Body: 3-4 sentences max — connect their likely pain to your specific offer naturally\n4. CTA: ONE low-friction ask (15-min call, reply with a word, etc.)\n5. Tone: human, peer-to-peer, NOT salesy or corporate\n6. Total email body under 120 words\n7. Sign off with sender name\n\nRespond ONLY with valid JSON in this exact format (no markdown, no extra text):\n{\n  \"subject\": \"...\",\n  \"body\": \"...\",\n  \"icebreaker\": \"...\",\n  \"estimated_open_rate\": \"...\"\n}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Generate Cold Email (AI)",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.7,
      "position": [1100, 200],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Split Leads').item.json;\nlet aiResponse;\n\ntry {\n  const raw = $input.item.json.message.content;\n  // Extract JSON block from AI response\n  const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n  if (!jsonMatch) throw new Error('No JSON found in AI response');\n  aiResponse = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  // Fallback template if AI parsing fails\n  aiResponse = {\n    subject: `Quick thought on ${lead.company}'s ops`,\n    body: `Hi ${lead.name},\\n\\nI noticed you're doing great work as ${lead.role} at ${lead.company}. I help teams like yours automate repetitive workflows and save 10+ hours/week.\\n\\nWould a 15-min call be worth exploring?\\n\\nBest,\\n${$('Set Variables').first().json.sender_name}`,\n    icebreaker: `Your role at ${lead.company}`,\n    estimated_open_rate: '25-35%'\n  };\n}\n\nreturn {\n  lead_name: lead.name || '',\n  lead_email: lead.email || '',\n  lead_role: lead.role || '',\n  lead_company: lead.company || '',\n  lead_industry: lead.industry || '',\n  lead_linkedin: lead.linkedin_url || '',\n  email_subject: aiResponse.subject,\n  email_body: aiResponse.body,\n  icebreaker: aiResponse.icebreaker,\n  estimated_open_rate: aiResponse.estimated_open_rate,\n  generated_at: new Date().toISOString(),\n  status: 'generated'\n};"
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Parse Email Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 200]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "YOUR_GOOGLE_SHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Leads"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Lead Name": "={{ $json.lead_name }}",
            "Email": "={{ $json.lead_email }}",
            "Role": "={{ $json.lead_role }}",
            "Company": "={{ $json.lead_company }}",
            "Industry": "={{ $json.lead_industry }}",
            "LinkedIn URL": "={{ $json.lead_linkedin }}",
            "Email Subject": "={{ $json.email_subject }}",
            "Email Body": "={{ $json.email_body }}",
            "Icebreaker Used": "={{ $json.icebreaker }}",
            "Est. Open Rate": "={{ $json.estimated_open_rate }}",
            "Generated At": "={{ $json.generated_at }}",
            "Status": "={{ $json.status }}"
          }
        },
        "options": {}
      },
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Log to Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1540, 80],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets OAuth"
        }

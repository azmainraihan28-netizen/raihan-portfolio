      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, emails_generated: $('Aggregate Results').item.json.data.length, mode: $('Set Variables').first().json.mode, message: 'Cold emails generated successfully' }) }}",
        "options": {}

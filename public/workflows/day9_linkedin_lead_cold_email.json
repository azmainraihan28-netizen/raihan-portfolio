        "text": "=📧 *Cold Email Batch Complete!*\n\n✅ *Emails Generated:* {{ $json.data.length }}\n🎯 *Mode:* {{ $('Set Variables').first().json.mode === 'send' ? 'Sent 🚀' : 'Saved as Drafts 📝' }}\n⏰ *Completed:* {{ new Date().toLocaleString() }}\n\n_Review your Gmail or Google Sheets for all generated emails._",
        "otherOptions": {}
      },

    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/pages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "notionApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"parent\": { \"database_id\": \"{{ $json.notion_db_id }}\" },\n  \"properties\": {\n    \"Name\": { \"title\": [{ \"text\": { \"content\": \"{{ $json.article_title }}\" } }] },\n    \"Category\": { \"select\": { \"name\": \"{{ $json.category }}\" } },\n    \"Status\": { \"select\": { \"name\": \"Draft\" } },\n    \"Difficulty\": { \"select\": { \"name\": \"{{ $json.difficulty_level }}\" } },\n    \"Summary\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.article_summary.substring(0,2000) }}\" } }] },\n    \"Source Ticket\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.ticket_id }}\" } }] },\n    \"Read Time\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.estimated_read_time }}\" } }] }\n  },\n  \"children\": [\n    {\n      \"object\": \"block\",\n      \"type\": \"paragraph\",\n      \"paragraph\": {\n        \"rich_text\": [{ \"type\": \"text\", \"text\": { \"content\": \"{{ $json.article_content.substring(0,2000) }}\" } }]\n      }\n    }\n  ]\n}",
        "options": {}
      },

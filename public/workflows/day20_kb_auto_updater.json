    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "content": "You are a knowledge base management AI. Analyze resolved support tickets and decide whether to create a new KB article, update an existing one, or skip (if the issue is too specific to be reusable).\n\nRespond with ONLY a valid JSON object (no markdown, no explanation):\n\n{\n  \"action\": \"create\" | \"update\" | \"skip\",\n  \"confidence\": 1-10,\n  \"article_title\": \"Clear, searchable title for the KB article\",\n  \"article_slug\": \"url-friendly-slug\",\n  \"category\": \"Category name\",\n  \"tags\": [\"tag1\", \"tag2\", \"tag3\"],\n  \"difficulty_level\": \"beginner\" | \"intermediate\" | \"advanced\",\n  \"estimated_read_time\": \"X min read\",\n  \"article_summary\": \"One sentence description of what this article covers\",\n  \"article_content\": \"Full markdown article content. Include: Introduction, Problem Description, Step-by-Step Solution, Tips & Notes, Related Topics. 300-500 words, written for end users.\",\n  \"update_notes\": \"If action is update: what specifically should be added or changed\",\n  \"skip_reason\": \"If action is skip: why this ticket does not warrant a KB article\"\n}\n\nDecision rules:\n- Create: issue is likely to recur, solution is generalizable, helps future customers self-serve\n- Update: existing_article_id is provided AND ticket adds meaningful new information\n- Skip: ticket is highly account-specific, a one-time bug, or internal ops only\n- Confidence 1-4 = lean skip, 5-7 = borderline, 8-10 = definitely publish"
            },
            {
              "content": "=Ticket ID: {{ $json.ticket_id }}\nProduct: {{ $json.product }}\nCategory: {{ $json.category }}\n\nTicket Title: {{ $json.ticket_title }}\n\nTicket Description:\n{{ $json.ticket_description }}\n\nResolution:\n{{ $json.resolution }}\n\nExisting Article ID (if updating): {{ $json.existing_article_id || 'None' }}",
              "role": "user"
            }
          ]
        },
        "options": {}
      },
      "id": "node_openai",
      "name": "OpenAI — KB Decision + Draft Article",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [900, 220]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst raw = item.json?.message?.content || item.json?.choices?.[0]?.message?.content || '';\n\nlet kb = {};\ntry {\n  const clean = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n  kb = JSON.parse(clean);\n} catch(e) {\n  kb = {\n    action: 'skip',\n    confidence: 1,\n    article_title: 'Parse Error',\n    article_slug: 'parse-error',\n    category: 'Uncategorized',\n    tags: [],\n    difficulty_level: 'beginner',\n    estimated_read_time: '2 min read',\n    article_summary: 'AI response could not be parsed',\n    article_content: raw || 'No content available',\n    update_notes: '',\n    skip_reason: 'AI response parse error: ' + e.message\n  };\n}\n\nconst upstream = $('Set — Normalize Inputs').first().json;\n\nreturn [{\n  json: {\n    ...upstream,\n    action: kb.action || 'skip',\n    confidence: kb.confidence || 5,\n    article_title: kb.article_title || 'Untitled Article',\n    article_slug: kb.article_slug || 'untitled-article',\n    category: kb.category || upstream.category || 'General',\n    tags: Array.isArray(kb.tags) ? kb.tags.join(', ') : (kb.tags || ''),\n    tags_array: Array.isArray(kb.tags) ? kb.tags : [],\n    difficulty_level: kb.difficulty_level || 'beginner',\n    estimated_read_time: kb.estimated_read_time || '3 min read',\n    article_summary: kb.article_summary || '',\n    article_content: kb.article_content || '',\n    update_notes: kb.update_notes || '',\n    skip_reason: kb.skip_reason || '',\n    processed_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "node_code_parse",
      "name": "Code — Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 220]
    },

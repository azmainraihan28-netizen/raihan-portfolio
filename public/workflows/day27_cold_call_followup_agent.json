    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"success\",\n  \"call_sid\": \"{{ $json.call_sid }}\",\n  \"prospect\": \"{{ $json.prospect_name }}\",\n  \"sms_sent\": true,\n  \"email_sent\": {{ $json.prospect_email ? 'true' : 'false' }},\n  \"lead_temperature\": \"{{ $json.lead_temperature }}\",\n  \"urgency_score\": {{ $json.urgency_score }},\n  \"next_step\": \"{{ $json.next_step }}\",\n  \"follow_up_in_days\": {{ $json.follow_up_day }}\n}",
        "options": {

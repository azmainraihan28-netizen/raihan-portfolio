      "id": "node_if_qualify",
      "name": "IF — Qualifying Call?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [540, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'skipped', reason: 'Call too short or not completed', call_sid: $json.call_sid, duration: $json.call_duration }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "node_respond_skip",
      "name": "Respond — Skip (Short/Incomplete)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [760, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.openai_key }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert B2B sales follow-up copywriter. Generate personalized, warm, concise follow-up messages after a sales call. Output must be valid JSON.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a follow-up package for a completed sales call.\\n\\nCall Details:\\n- Prospect Name: {{ $json.prospect_name }}\\n- Prospect Company: {{ $json.prospect_company }}\\n- Call Duration: {{ $json.call_duration }} seconds\\n- Sales Rep: {{ $json.rep_name }}\\n- Product/Service: {{ $json.product_name }}\\n- Call Notes: {{ $json.call_notes || 'No notes provided' }}\\n\\nGenerate a JSON object with these exact fields:\\n{\\n  \\\"sms_message\\\": \\\"A warm, friendly SMS follow-up (max 160 characters). Reference the call. No generic templates. Sound human.\\\",\\n  \\\"email_subject\\\": \\\"A compelling email subject line (max 60 chars). Reference the call.\\\",\\n  \\\"email_body_html\\\": \\\"A personalized HTML email body. 3-4 short paragraphs. Reference specific topics from call notes if available. Include a clear CTA. Professional but warm tone. No fluff.\\\",\\n  \\\"next_step\\\": \\\"Recommended next action (e.g. 'Schedule demo', 'Send proposal', 'Follow up in 3 days')\\\",\\n  \\\"lead_temperature\\\": \\\"hot | warm | cold — based on call duration and notes\\\",\\n  \\\"follow_up_day\\\": \\\"Number of days until next follow-up (1, 3, 5, or 7)\\\",\\n  \\\"talking_points_summary\\\": \\\"2-3 sentence summary of what was likely discussed based on notes\\\",\\n  \\\"urgency_score\\\": \\\"1-10 integer — how urgently should the rep follow up?\\\"\\\n}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "node_openai",
      "name": "OpenAI — Generate Follow-Up Package",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [760, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nlet parsed = {};\ntry {\n  const raw = item.choices?.[0]?.message?.content || '{}';\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = {\n    sms_message: `Hi ${item.prospect_name || 'there'}, great speaking with you! I'll send over the details we discussed. Let me know if you have any questions.`,\n    email_subject: `Great speaking with you today, ${item.prospect_name || 'there'}!`,\n    email_body_html: `<p>Hi ${item.prospect_name || 'there'},</p><p>It was a pleasure speaking with you today about ${item.product_name || 'our solution'}. I wanted to follow up and share some additional information.</p><p>Please don't hesitate to reach out if you have any questions. I look forward to our next conversation.</p><p>Best regards,<br>${item.rep_name || 'Your Sales Team'}</p>`,\n    next_step: 'Follow up in 3 days',\n    lead_temperature: 'warm',\n    follow_up_day: 3,\n    talking_points_summary: 'General product discussion.',\n    urgency_score: 5\n  };\n}\n\nreturn [{\n  json: {\n    // Pass through all previous fields\n    call_sid: item.call_sid,\n    call_status: item.call_status,\n    call_duration: item.call_duration,\n    from_number: item.from_number,\n    to_number: item.to_number,\n    prospect_name: item.prospect_name,\n    prospect_email: item.prospect_email,\n    prospect_company: item.prospect_company,\n    call_notes: item.call_notes,\n    rep_name: item.rep_name,\n    product_name: item.product_name,\n    twilio_account_sid: item.twilio_account_sid,\n    twilio_auth_token: item.twilio_auth_token,\n    openai_key: item.openai_key,\n    sheet_id: item.sheet_id,\n    slack_enabled: item.slack_enabled,\n    slack_channel: item.slack_channel,\n    timestamp: item.timestamp,\n    // AI outputs\n    sms_message: (parsed.sms_message || '').substring(0, 160),\n    email_subject: parsed.email_subject || 'Great speaking with you today!',\n    email_body_html: parsed.email_body_html || '',\n    next_step: parsed.next_step || 'Follow up in 3 days',\n    lead_temperature: parsed.lead_temperature || 'warm',\n    follow_up_day: parseInt(parsed.follow_up_day) || 3,\n    talking_points_summary: parsed.talking_points_summary || '',\n    urgency_score: parseInt(parsed.urgency_score) || 5\n  }\n}];"
      },
      "id": "node_code_parse",
      "name": "Code — Parse AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{ $json.twilio_account_sid }}/Messages.json",

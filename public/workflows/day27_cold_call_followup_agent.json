          }
        },
        "options": {}
      },
      "id": "node_sheets",
      "name": "Google Sheets — Log Call + Follow-Up",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1200, 500],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "sheets_cred",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "s1",
              "leftValue": "={{ $json.slack_enabled }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node_if_slack",
      "name": "IF — Slack Enabled?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1420, 300]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $json.slack_channel }}",
          "mode": "name"
        },
        "blocksUi": "=[\n  {\n    \"type\": \"header\",\n    \"text\": {\n      \"type\": \"plain_text\",\n      \"text\": \"📞 Call Follow-Up Sent\",\n      \"emoji\": true\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"fields\": [\n      { \"type\": \"mrkdwn\", \"text\": \"*Prospect:*\\n{{ $json.prospect_name }} @ {{ $json.prospect_company }}\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Call Duration:*\\n{{ Math.floor($json.call_duration / 60) }}m {{ $json.call_duration % 60 }}s\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Lead Temperature:*\\n{{ $json.lead_temperature === 'hot' ? '🔥 Hot' : $json.lead_temperature === 'warm' ? '☀️ Warm' : '❄️ Cold' }}\" },\n      { \"type\": \"mrkdwn\", \"text\": \"*Urgency Score:*\\n{{ $json.urgency_score }}/10\" }\n    ]\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*📋 Summary:*\\n{{ $json.talking_points_summary }}\"\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*✅ Next Step:* {{ $json.next_step }}\\n*📅 Follow Up In:* {{ $json.follow_up_day }} days\"\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*📱 SMS Sent:*\\n_{{ $json.sms_message }}_\"\n    }\n  },\n  {\n    \"type\": \"context\",\n    \"elements\": [\n      {\n        \"type\": \"mrkdwn\",\n        \"text\": \"Rep: {{ $json.rep_name }} | Call SID: {{ $json.call_sid }} | {{ $json.timestamp }}\"\n      }\n    ]\n  }\n]",
        "otherOptions": {}
      },
      "id": "node_slack",
      "name": "Slack — Manager Alert",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [1640, 200],
      "credentials": {
        "slackApi": {
          "id": "slack_cred",

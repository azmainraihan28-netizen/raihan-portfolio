        "text": "=🛒 *High-Value Cart Recovery Triggered!*\n\n👤 *Customer:* {{ $('Parse AI Email').first().json.customerName }} ({{ $('Parse AI Email').first().json.customerEmail }})\n💰 *Cart Value:* {{ $('Parse AI Email').first().json.currency }} {{ $('Parse AI Email').first().json.totalValue }}\n🛍️ *Items:* {{ $('Parse AI Email').first().json.cartSummary }}\n📧 *Email Subject:* {{ $('Parse AI Email').first().json.emailSubject }}\n🔗 *Checkout:* {{ $('Parse AI Email').first().json.checkoutUrl }}\n\n✅ Discount code COMEBACK10 included in email.",
        "otherOptions": {}

{
  "name": "Day 12 — Shopify Abandoned Cart AI Follow-Up",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "shopify-abandoned-cart",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Shopify Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extract checkout data from Shopify abandoned_checkouts/create webhook\nconst body = $input.first().json;\n\nconst checkout = body;\n\nconst cartItems = (checkout.line_items || []).map(item => ({\n  title: item.title || 'Unknown Product',\n  quantity: item.quantity || 1,\n  price: parseFloat(item.price || 0)\n}));\n\nconst totalValue = parseFloat(checkout.total_price || 0);\nconst currency = checkout.currency || 'USD';\nconst customerEmail = checkout.email || '';\nconst customerName = (checkout.billing_address?.first_name || checkout.shipping_address?.first_name || 'there');\nconst checkoutUrl = checkout.abandoned_checkout_url || '#';\nconst checkoutId = checkout.id || '';\nconst shopDomain = checkout.domain || '';\n\nif (!customerEmail) {\n  throw new Error('NO_EMAIL: Customer email missing — skipping follow-up');\n}\n\nreturn [{\n  json: {\n    checkoutId,\n    shopDomain,\n    customerEmail,\n    customerName,\n    cartItems,\n    totalValue,\n    currency,\n    checkoutUrl,\n    isHighValue: totalValue >= 100,\n    cartSummary: cartItems.map(i => `${i.quantity}x ${i.title} ($${i.price})`).join(', '),\n    itemCount: cartItems.length\n  }\n}];\n"
      },
      "id": "node-extract",
      "name": "Extract Checkout Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "amount": 1,
        "unit": "hours"
      },
      "id": "node-wait",
      "name": "Wait 1 Hour",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [680, 300],
      "webhookId": "wait-webhook-id"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{ $json.shopDomain }}/admin/api/2024-01/orders.json?email={{ $json.customerEmail }}&status=any&created_at_min={{ new Date(Date.now() - 2*60*60*1000).toISOString() }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-check-order",
      "name": "Check If Order Placed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "shopify-admin-api-cred",
          "name": "Shopify Admin API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-order-check",
              "leftValue": "={{ $json.orders.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-order",
      "name": "Order Already Placed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "create",
        "model": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an expert e-commerce copywriter who writes short, warm, and highly personalized abandoned cart recovery emails. You write as if you're a friendly human from the store — never robotic or salesy. Keep it under 150 words."
            },
            {
              "role": "user",
              "content": "=Write an abandoned cart recovery email for:\n\nCustomer Name: {{ $('Extract Checkout Data').first().json.customerName }}\nCart Items: {{ $('Extract Checkout Data').first().json.cartSummary }}\nCart Total: {{ $('Extract Checkout Data').first().json.currency }} {{ $('Extract Checkout Data').first().json.totalValue }}\nCheckout Link: {{ $('Extract Checkout Data').first().json.checkoutUrl }}\nHigh Value Cart (100+): {{ $('Extract Checkout Data').first().json.isHighValue }}\n\nIf high value cart, include a 10% off discount code: COMEBACK10\nIf not high value, just remind them warmly without a discount.\n\nReturn ONLY valid JSON in this exact format:\n{\n  \"subject\": \"...\",\n  \"preheader\": \"...\",\n  \"body_html\": \"...\",\n  \"icebreaker\": \"one personalized opening sentence only\"\n}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-openai",
      "name": "AI Writes Recovery Email",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1340, 160],
      "credentials": {
        "openAiApi": {
          "id": "openai-api-cred",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.message?.content || $input.first().json.choices?.[0]?.message?.content || '';\n\nlet parsed;\ntry {\n  const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(jsonMatch ? jsonMatch[0] : raw);\n} catch(e) {\n  // Fallback email if AI parsing fails\n  parsed = {\n    subject: `Hey {{ $('Extract Checkout Data').first().json.customerName }}, you forgot something!`,\n    preheader: 'Your cart is waiting for you...',\n    body_html: `<p>Hi {{ $('Extract Checkout Data').first().json.customerName }},</p><p>You left some great items in your cart. Come back and complete your order!</p><p><a href='{{ $('Extract Checkout Data').first().json.checkoutUrl }}'>Complete My Order</a></p>`,\n    icebreaker: 'We noticed you left something behind.'\n  };\n}\n\nconst checkoutData = $('Extract Checkout Data').first().json;\n\nreturn [{\n  json: {\n    ...checkoutData,\n    emailSubject: parsed.subject,\n    emailPreheader: parsed.preheader,\n    emailBodyHtml: parsed.body_html,\n    icebreaker: parsed.icebreaker,\n    generatedAt: new Date().toISOString()\n  }\n}];\n"
      },
      "id": "node-parse",
      "name": "Parse AI Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 160]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
